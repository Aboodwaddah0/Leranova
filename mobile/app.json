{
  "expo": {
    "name": "Learnova",
    "slug": "learnova-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.learnova.mobile"
    },
    "android": {
      "package": "com.learnova.mobile",
      "googleServicesFile": "./android/app/google-services.json"
    },
    "plugins": [
      "expo-secure-store",
      "expo-av",
      "expo-file-system",
      "expo-image-picker",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#6366f1",
          "sounds": []
        }
      ]
    ]
  }
}
