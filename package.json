{
  "name": "backend",
  "version": "1.0.0",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:reset": "node scripts/dbReset.js",
    "db:seed": "node scripts/dbSeed.js",
    "db:seed:school": "node scripts/schoolTestSeed.js",
    "db:refresh": "npm run db:reset && npm run plan:seed && npm run db:seed",
    "plan:add": "node scripts/addPlan.js",
    "plan:seed": "node scripts/resetPlans.js",
    "admin:setup": "node scripts/setupAdminUser.js",
    "test:api": "newman run postman/Learnova_Backend.postman_collection.json -e postman/Learnova_Local.postman_environment.json",
    "migrate:cloudinary:paths:dry": "node scripts/migrateCloudinaryLessonPaths.js",
    "migrate:cloudinary:paths": "node scripts/migrateCloudinaryLessonPaths.js --apply"
  },
