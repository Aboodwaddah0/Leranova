  subject        course?           @relation(fields: [subjectId], references: [id], onDelete: SetNull, onUpdate: Restrict, map: "fk_attendance_subject")
  organization   organization      @relation(fields: [orgId], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_attendance_org")
  marker         user              @relation("attendance_marker", fields: [markedBy], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "fk_attendance_marker")
  academic_year  academic_year?    @relation(fields: [academicYearId], references: [id], onDelete: SetNull, onUpdate: Restrict, map: "fk_attendance_academic_year")
