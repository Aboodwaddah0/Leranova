generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model academy_user {
  user_academy_id Int          @id
  OrgId           Int
  organization    organization @relation(fields: [OrgId], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_academy_user_org")
  user            user         @relation(fields: [user_academy_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_academy_user_user")
  enrollment      enrollment[]
  createdAt       DateTime     @default(now()) @db.Timestamp(0)
  updatedAt       DateTime     @default(now()) @updatedAt @db.Timestamp(0)

  @@index([OrgId], map: "fk_academy_user_org")
}


model chat_participants {
  id           Int                             @id @default(autoincrement())
  chat_id      Int
  user_id      Int
  role_in_chat chat_participants_role_in_chat? @default(member)
  joined_at    DateTime                        @default(now()) @db.Timestamp(0)
  chats        chats                           @relation(fields: [chat_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_chat_participants_chat")
  user         user                            @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_chat_participants_user")

  @@unique([chat_id, user_id], map: "uq_chat_participant")
  @@index([chat_id], map: "idx_chat_participants_chat_id")
  @@index([user_id], map: "idx_chat_participants_user_id")
}

model chats {
  id                Int                 @id @default(autoincrement())
  organization_id   Int
  subject_id        Int?
  created_by        Int
  type              chats_type
  title             String?             @db.VarChar(255)
  created_at        DateTime            @default(now()) @db.Timestamp(0)
  chat_participants chat_participants[]
  user              user                @relation(fields: [created_by], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_chats_created_by")
  organization      organization        @relation(fields: [organization_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_chats_organization")
  subject           subject?            @relation(fields: [subject_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_chats_subject")
  messages          messages[]

  @@index([created_by], map: "fk_chats_created_by")
  @@index([organization_id], map: "idx_chats_organization_id")
  @@index([subject_id], map: "idx_chats_subject_id")
  @@index([type], map: "idx_chats_type")
}

model comment {
  id        Int      @id @default(autoincrement())
  lesson_id Int?
  User_id   Int
  time      DateTime @default(now()) @db.Timestamp(0)
  content   String   @db.Text
  lesson    lesson?  @relation(fields: [lesson_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_comment_lesson")
  user      user     @relation(fields: [User_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_comment_user")

  @@index([lesson_id], map: "idx_comment_lesson_id")
  @@index([User_id], map: "idx_comment_user_id")
}

model course {
  id           Int          @id @default(autoincrement())
  Org_id       Int
  Name         String       @db.VarChar(255)
  Description  String?      @db.Text
  Thumbnail    String?      @db.VarChar(500)
  Start        DateTime?    @db.Date
  End          DateTime?    @db.Date
  organization organization @relation(fields: [Org_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_course_org")
  student      student[]
  subject      subject[]
  enrollment   enrollment[]
  createdAt    DateTime     @default(now()) @db.Timestamp(0)
  updatedAt    DateTime     @default(now()) @updatedAt @db.Timestamp(0)

  @@index([Org_id], map: "idx_course_org_id")
}

model enrollment {
  user_Academy_id Int
  Course_id       Int
  academy_user    academy_user @relation(fields: [user_Academy_id], references: [user_academy_id], onDelete: Cascade, onUpdate: Restrict, map: "fk_enrollment_academy_user")
  course          course       @relation(fields: [Course_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_enrollment_course")
  createdAt       DateTime     @default(now()) @db.Timestamp(0)
  updatedAt       DateTime     @default(now()) @updatedAt @db.Timestamp(0)

  @@id([user_Academy_id, Course_id])
  @@index([Course_id], map: "fk_enrollment_course")
}

model lesson {
  id                Int                @id @default(autoincrement())
  Subject_id        Int
  name              String             @db.VarChar(255)
  Description       String?            @db.Text
  comment           comment[]
  lesson_transcripts lesson_transcripts[]
  subject           subject            @relation(fields: [Subject_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_lesson_subject")
  rag_assets        lesson_rag_asset[]
  attachments       lesson_attachment[]
  createdAt         DateTime           @default(now()) @db.Timestamp(0)
  updatedAt         DateTime           @default(now()) @updatedAt @db.Timestamp(0)

  @@index([Subject_id], map: "idx_lesson_subject_id")
}

model lesson_attachment {
  id               Int      @id @default(autoincrement())
  lessonId         Int
  fileUrl          String   @db.VarChar(500)
  filePublicId     String   @db.VarChar(255)
  fileResourceType String   @db.VarChar(50)
  mimeType         String?  @db.VarChar(100)
  originalName     String?  @db.VarChar(255)
  fileType         lesson_attachment_file_type
  sizeBytes        BigInt?
  createdAt        DateTime @default(now()) @db.Timestamp(0)
  updatedAt        DateTime @default(now()) @updatedAt @db.Timestamp(0)
  lesson           lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_lesson_attachment_lesson")

  @@index([lessonId], map: "idx_lesson_attachment_lesson_id")
  @@index([fileType], map: "idx_lesson_attachment_file_type")
}

model lesson_rag_asset {
  id            Int      @id @default(autoincrement())
  lessonId      Int
  type          String   @db.VarChar(20)
  fileUrl       String   @db.VarChar(500)
  extractedText String?  @db.LongText
  sourceName    String?  @db.VarChar(255)
  createdAt     DateTime @default(now()) @db.Timestamp(0)
  lesson        lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_lesson_rag_asset_lesson")

  @@index([lessonId], map: "idx_lesson_rag_asset_lesson_id")
  @@index([type], map: "idx_lesson_rag_asset_type")
}

model lesson_transcripts {
  id         Int      @id @default(autoincrement())
  lesson_id  Int
  transcript String   @db.LongText
  created_at DateTime @default(now()) @db.Timestamp(0)
  lesson     lesson   @relation(fields: [lesson_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_lesson_transcripts_lesson")

  @@index([lesson_id], map: "idx_lesson_transcripts_lesson_id")
}

model marks {
  id         Int       @id @default(autoincrement())
  Student_id Int
  Subject_id Int
  Numbers    Decimal   @db.Decimal(5, 2)
  OutOf      Decimal   @default(100) @db.Decimal(5, 2)
  ExamPercentage Decimal @default(100) @db.Decimal(5, 2)
  MarkType   String    @default("EXAM") @db.VarChar(50)
  time       DateTime? @db.Date
  student    student   @relation(fields: [Student_id], references: [Student_id], onDelete: Cascade, onUpdate: Restrict, map: "fk_marks_student")
  subject    subject   @relation(fields: [Subject_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_marks_subject")
  createdAt  DateTime  @default(now()) @db.Timestamp(0)
  updatedAt  DateTime  @default(now()) @updatedAt @db.Timestamp(0)

  @@index([Subject_id], map: "idx_marks_subject_id")
  @@index([Student_id], map: "idx_marks_student_id")
}

model message_attachments {
  id          Int      @id @default(autoincrement())
  message_id  Int
  file_name   String   @db.VarChar(255)
  file_url    String   @db.VarChar(500)
  file_type   String?  @db.VarChar(100)
  file_size   BigInt?
  uploaded_at DateTime @default(now()) @db.Timestamp(0)
  messages    messages @relation(fields: [message_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_message_attachments_message")

  @@index([message_id], map: "idx_message_attachments_message_id")
}

model messages {
  id                  Int                    @id @default(autoincrement())
  chat_id             Int
  sender_user_id      Int
  message_type        messages_message_type? @default(text)
  content             String                 @db.Text
  sent_at             DateTime               @default(now()) @db.Timestamp(0)
  edited_at           DateTime?              @db.Timestamp(0)
  is_deleted          Boolean?               @default(false)
  message_attachments message_attachments[]
  chats               chats                  @relation(fields: [chat_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_messages_chat")
  user                user                   @relation(fields: [sender_user_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_messages_sender")

  @@index([chat_id], map: "idx_messages_chat_id")
  @@index([sender_user_id], map: "idx_messages_sender_user_id")
  @@index([sent_at], map: "idx_messages_sent_at")
}

model notification {
  id        Int      @id @default(autoincrement())
  User_id   Int
  content   String   @db.Text
  Type      String   @db.VarChar(100)
  Url       String?  @db.VarChar(500)
  isSeen    Boolean? @default(false)
  user      user     @relation(fields: [User_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_notification_user")
  createdAt DateTime @default(now()) @db.Timestamp(0)
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamp(0)

  @@index([User_id], map: "idx_notification_user_id")
}

model organization {
  id              Int               @id @default(autoincrement())
  Name            String            @db.VarChar(255)
  Email           String            @unique(map: "Email") @db.VarChar(255)
  Password_Hashed String            @db.VarChar(255)
  Phone           String?           @db.VarChar(50)
  Founded         DateTime?         @db.Date
  Address         String?           @db.VarChar(255)
  PhoneNumber     String?           @db.VarChar(50)
  Description     String?           @db.Text
  Role            organization_Role
  academy_user    academy_user[]
  chats           chats[]
  course          course[]
  student         student[]
  teacher         teacher[]
  status          organization_status @default(PENDING)
  createdAt       DateTime          @default(now()) @db.Timestamp(0)
  updatedAt       DateTime          @default(now()) @updatedAt @db.Timestamp(0)
}

model parent {
  Parent_id Int      @id
  Work      String?  @db.VarChar(255)
  user      user     @relation(fields: [Parent_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_parent_user")
  student   student[]
  createdAt DateTime @default(now()) @db.Timestamp(0)
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamp(0)
}

model student {
  Student_id   Int          @id
  Parent_id    Int?
  OrgId        Int
  Course_id    Int?
  course       course?      @relation(fields: [Course_id], references: [id], onUpdate: Restrict, map: "fk_student_course")
  marks        marks[]
  organization organization @relation(fields: [OrgId], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_student_org")
  parent       parent?      @relation(fields: [Parent_id], references: [Parent_id], onUpdate: Restrict, map: "fk_student_parent")
  user         user         @relation(fields: [Student_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_student_user")
  createdAt    DateTime     @default(now()) @db.Timestamp(0)
  updatedAt    DateTime     @default(now()) @updatedAt @db.Timestamp(0)

  @@index([Course_id], map: "idx_student_course_id")
  @@index([OrgId], map: "idx_student_org_id")
  @@index([Parent_id], map: "idx_student_parent_id")
}

model subject {
  id          Int      @id @default(autoincrement())
  Course_id   Int
  Teacher_id  Int
  name        String   @db.VarChar(255)
  Description String?  @db.Text
  chats       chats[]
  lesson      lesson[]
  marks       marks[]
  course      course   @relation(fields: [Course_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_subject_course")
  teacher     teacher  @relation(fields: [Teacher_id], references: [Teacher_id], onDelete: Cascade, onUpdate: Restrict, map: "fk_subject_teacher")
  createdAt   DateTime @default(now()) @db.Timestamp(0)
  updatedAt   DateTime @default(now()) @updatedAt @db.Timestamp(0)

  @@index([Course_id], map: "idx_subject_course_id")
  @@index([Teacher_id], map: "idx_subject_teacher_id")
}

model teacher {
  Teacher_id     Int           @id
  OrgId          Int
  Work           String?       @db.VarChar(255)
  specialization String?       @db.VarChar(255)
  bio            String?       @db.Text
  createdAt      DateTime      @default(now()) @db.Timestamp(0)
  organization   organization  @relation(fields: [OrgId], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_teacher_org")
  subject        subject[]
  user           user          @relation(fields: [Teacher_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_teacher_user")

  @@index([OrgId], map: "idx_teacher_org_id")
}

model user {
  id                Int                 @id @default(autoincrement())
  name              String              @db.VarChar(255)
  age               Int?
  gender            user_Gender?
  email             String              @unique(map: "Email") @db.VarChar(255)
  passwordHashed    String              @db.VarChar(255)
  address           String?             @db.VarChar(255)
  role              user_Role
  academy_user      academy_user?
  chat_participants chat_participants[]
  chats             chats[]
  comment           comment[]
  messages          messages[]
  notification      notification[]
  parent            parent?
  student           student?
  teacher           teacher?
  createdAt         DateTime            @default(now()) @db.Timestamp(0)
  updatedAt         DateTime            @default(now()) @updatedAt @db.Timestamp(0)
}

enum chat_participants_role_in_chat {
  member
  admin
  teacher
  student
}

enum messages_message_type {
  text
  image
  file
  voice
}

enum user_Gender {
  FEMALE
  MALE
}

enum chats_type {
  GROUP
  PRIVATE
}

enum user_Role {
  STUDENT
  PARENT
  ADMIN
  ACADEMY
  TEACHER
}

enum organization_Role {
  ACADEMY
  SCHOOL
}

enum organization_status {
  PENDING
  APPROVED
  REJECTED
}

enum lesson_attachment_file_type {
  PDF
  DOCX
  TXT
  IMAGE
  VIDEO
  AUDIO
  OTHER
}
    
    