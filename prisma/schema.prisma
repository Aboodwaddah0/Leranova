generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model academy_user {
  user_academy_id         Int                        @id
  OrgId                   Int
  DOB                     DateTime?                  @db.Date
  AcademicStatus          String                     @default("ACTIVE") @db.VarChar(20)
  organization            organization               @relation(fields: [OrgId], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_academy_user_org")
  user                    user                       @relation(fields: [user_academy_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_academy_user_user")
  enrollment              enrollment[]
  student_course_payment  student_course_payment[]
  subject_subscriptions   student_subject_subscription[]
  createdAt               DateTime                   @default(now()) @db.Timestamp(0)
  updatedAt               DateTime                   @default(now()) @updatedAt @db.Timestamp(0)

  @@index([OrgId], map: "fk_academy_user_org")
  @@index([AcademicStatus], map: "idx_academy_user_academic_status")
}

model chat_participants {
  id           Int                             @id @default(autoincrement())
  chat_id      Int
  user_id      Int
  role_in_chat chat_participants_role_in_chat? @default(member)
  joined_at    DateTime                        @default(now()) @db.Timestamp(0)
  chats        chats                           @relation(fields: [chat_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_chat_participants_chat")
  user         user                            @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_chat_participants_user")

  @@unique([chat_id, user_id], map: "uq_chat_participant")
  @@index([chat_id], map: "idx_chat_participants_chat_id")
  @@index([user_id], map: "idx_chat_participants_user_id")
}

model chats {
  id                Int                 @id @default(autoincrement())
  organization_id   Int
  course_id         Int?                @unique
  class_id          Int?
  subject_id        Int?
  created_by        Int
  type              chats_type
  title             String?             @db.VarChar(255)
  created_at        DateTime            @default(now()) @db.Timestamp(0)
  chat_participants chat_participants[]
  user              user                @relation(fields: [created_by], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_chats_created_by")
  organization      organization        @relation(fields: [organization_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_chats_organization")
  course            course?             @relation(fields: [course_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_chats_course")
  subject           subject?            @relation(fields: [subject_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_chats_subject")
  messages          messages[]

  @@index([created_by], map: "fk_chats_created_by")
  @@index([organization_id], map: "idx_chats_organization_id")
  @@index([course_id], map: "idx_chats_course_id")
  @@index([class_id], map: "idx_chats_class_id")
  @@index([subject_id], map: "idx_chats_subject_id")
  @@index([type], map: "idx_chats_type")
  @@unique([organization_id, class_id], map: "uq_chats_org_class")
}

model comment {
  id        Int      @id @default(autoincrement())
  lesson_id Int?
  User_id   Int
  time      DateTime @default(now()) @db.Timestamp(0)
  content   String   @db.Text
  lesson    lesson?  @relation(fields: [lesson_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_comment_lesson")
  user      user     @relation(fields: [User_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_comment_user")

  @@index([lesson_id], map: "idx_comment_lesson_id")
  @@index([User_id], map: "idx_comment_user_id")
}

model course {
  id                     Int                       @id @default(autoincrement())
  Org_id                 Int
  Teacher_id             Int?
  Name                   String                    @db.VarChar(255)
  kind                   course_kind               @default(TRACK)
  GradeLevel             Int?
  Description            String?                   @db.Text
  Thumbnail              String?                   @db.VarChar(500)

  price                  Decimal                   @default(0) @db.Decimal(10, 2)
  isPaid                 Boolean                   @default(false)
  level                  String?                   @db.VarChar(20)

  organization           organization              @relation(fields: [Org_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_course_org")
  teacher                teacher?                  @relation(fields: [Teacher_id], references: [Teacher_id], onDelete: SetNull, onUpdate: Restrict, map: "fk_course_teacher")
  student                student[]
  subject                subject[]
  enrollment             enrollment[]

  chats                  chats[]

  student_course_payment student_course_payment[]

  createdAt              DateTime                  @default(now()) @db.Timestamp(0)
  updatedAt              DateTime                  @default(now()) @updatedAt @db.Timestamp(0)

  @@index([Org_id], map: "idx_course_org_id")
  @@index([Teacher_id], map: "idx_course_teacher_id")
  @@index([kind], map: "idx_course_kind")
  @@index([GradeLevel], map: "idx_course_grade_level")
  @@index([isPaid], map: "idx_course_is_paid")
}

model enrollment {
  user_Academy_id Int
  Course_id       Int
  academy_user    academy_user @relation(fields: [user_Academy_id], references: [user_academy_id], onDelete: Cascade, onUpdate: Restrict, map: "fk_enrollment_academy_user")
  course          course       @relation(fields: [Course_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_enrollment_course")
  createdAt       DateTime     @default(now()) @db.Timestamp(0)
  updatedAt       DateTime     @default(now()) @updatedAt @db.Timestamp(0)

  @@id([user_Academy_id, Course_id])
  @@index([Course_id], map: "fk_enrollment_course")
}

model student_course_payment {
  id                    Int          @id @default(autoincrement())
  user_Academy_id       Int
  Course_id             Int
  amount                Decimal      @db.Decimal(10, 2)
  paymentMethod         String       @default("STRIPE") @db.VarChar(50)
  status                String       @default("PENDING") @db.VarChar(50)
  stripePaymentIntentId String?      @db.VarChar(500)
  paidAt                DateTime?    @db.Timestamp(0)
  academy_user          academy_user @relation(fields: [user_Academy_id], references: [user_academy_id], onDelete: Cascade, onUpdate: Restrict, map: "fk_student_course_payment_academy_user")
  course                course       @relation(fields: [Course_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_student_course_payment_course")
  createdAt             DateTime     @default(now()) @db.Timestamp(0)
  updatedAt             DateTime     @default(now()) @updatedAt @db.Timestamp(0)

  @@unique([user_Academy_id, Course_id], map: "uq_student_course_payment")
  @@index([user_Academy_id], map: "idx_student_course_payment_user")
  @@index([Course_id], map: "idx_student_course_payment_course")
  @@index([status], map: "idx_student_course_payment_status")
}

model lesson {
  id                 Int                  @id @default(autoincrement())
  Subject_id         Int
  name               String               @db.VarChar(255)
  Description        String?              @db.Text
  comment            comment[]
  lesson_transcripts lesson_transcripts[]
  lesson_progress    lesson_progress[]
  subject            subject              @relation(fields: [Subject_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_lesson_subject")
  rag_assets         lesson_rag_asset[]
  attachments        lesson_attachment[]
  ai_content         lesson_ai_content?
  quiz               quiz?
  createdAt          DateTime             @default(now()) @db.Timestamp(0)
  updatedAt          DateTime             @default(now()) @updatedAt @db.Timestamp(0)

  @@index([Subject_id], map: "idx_lesson_subject_id")
}

model quiz {
  id           Int             @id @default(autoincrement())
  lessonId     Int             @unique
  title        String          @db.VarChar(255)
  description  String?         @db.Text
  difficulty   String          @default("MEDIUM") @db.VarChar(10)
  passingScore Int             @default(70)
  isPublished  Boolean         @default(false)
  lesson       lesson          @relation(fields: [lessonId], references: [id], onDelete: Cascade, map: "fk_quiz_lesson")
  questions    quiz_question[]
  attempts     quiz_attempt[]
  createdAt    DateTime        @default(now()) @db.Timestamp(0)
  updatedAt    DateTime        @default(now()) @updatedAt @db.Timestamp(0)

  @@index([lessonId], map: "idx_quiz_lesson_id")
}

model quiz_question {
  id            Int      @id @default(autoincrement())
  quizId        Int
  lang          String   @default("ar") @db.VarChar(5)
  question      String   @db.Text
  options       Json
  correctAnswer Int
  explanation   String?  @db.Text
  orderIndex    Int      @default(0)
  quiz          quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade, map: "fk_quiz_question_quiz")
  createdAt     DateTime @default(now()) @db.Timestamp(0)
  updatedAt     DateTime @default(now()) @updatedAt @db.Timestamp(0)

  @@index([quizId], map: "idx_quiz_question_quiz_id")
  @@index([quizId, lang], map: "idx_quiz_question_quiz_lang")
}

model quiz_attempt {
  id        Int      @id @default(autoincrement())
  quizId    Int
  studentId Int
  answers   Json
  score     Int
  isPassed  Boolean
  quiz      quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade, map: "fk_quiz_attempt_quiz")
  student   user     @relation(fields: [studentId], references: [id], onDelete: Cascade, map: "fk_quiz_attempt_user")
  createdAt DateTime @default(now()) @db.Timestamp(0)

  @@index([quizId], map: "idx_quiz_attempt_quiz_id")
  @@index([studentId], map: "idx_quiz_attempt_student_id")
}

model lesson_ai_content {
  id          Int       @id @default(autoincrement())
  lessonId    Int       @unique
  flashcards  Json
  mindmap     Json
  status      String    @default("draft")
  publishedAt DateTime?
  createdAt   DateTime  @default(now()) @db.Timestamp(0)
  updatedAt   DateTime  @default(now()) @updatedAt @db.Timestamp(0)
  lesson      lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_lesson_ai_content_lesson")
}

model lesson_attachment {
  id               Int                         @id @default(autoincrement())
  lessonId         Int
  fileUrl          String                      @db.VarChar(500)
  filePublicId     String                      @db.VarChar(255)
  fileResourceType String                      @db.VarChar(50)
  mimeType         String?                     @db.VarChar(100)
  originalName     String?                     @db.VarChar(255)
  fileType         lesson_attachment_file_type
  sizeBytes        BigInt?
  createdAt        DateTime                    @default(now()) @db.Timestamp(0)
  updatedAt        DateTime                    @default(now()) @updatedAt @db.Timestamp(0)
  lesson           lesson                      @relation(fields: [lessonId], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_lesson_attachment_lesson")

  @@index([lessonId], map: "idx_lesson_attachment_lesson_id")
  @@index([fileType], map: "idx_lesson_attachment_file_type")
}

model lesson_rag_asset {
  id            Int      @id @default(autoincrement())
  lessonId      Int
  type          String   @db.VarChar(20)
  fileUrl       String   @db.VarChar(500)
  extractedText String?  @db.LongText
  sourceName    String?  @db.VarChar(255)
  createdAt     DateTime @default(now()) @db.Timestamp(0)
  lesson        lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_lesson_rag_asset_lesson")

  @@index([lessonId], map: "idx_lesson_rag_asset_lesson_id")
  @@index([type], map: "idx_lesson_rag_asset_type")
}

model lesson_transcripts {
  id         Int      @id @default(autoincrement())
  lesson_id  Int
  transcript String   @db.LongText
  created_at DateTime @default(now()) @db.Timestamp(0)
  lesson     lesson   @relation(fields: [lesson_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_lesson_transcripts_lesson")

  @@index([lesson_id], map: "idx_lesson_transcripts_lesson_id")
}

model lesson_progress {
  id          Int      @id @default(autoincrement())
  studentId   Int
  lessonId    Int
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now()) @db.Timestamp(0)
  updatedAt   DateTime @default(now()) @updatedAt @db.Timestamp(0)
  student     user     @relation(fields: [studentId], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_lesson_progress_student")
  lesson      lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_lesson_progress_lesson")

  @@unique([studentId, lessonId], map: "uq_lesson_progress_student_lesson")
  @@index([studentId], map: "idx_lesson_progress_student")
  @@index([lessonId], map: "idx_lesson_progress_lesson")
}

model marks {
  id             Int       @id @default(autoincrement())
  Student_id     Int
  Subject_id     Int
  Numbers        Decimal   @db.Decimal(5, 2)
  OutOf          Decimal   @default(100) @db.Decimal(5, 2)
  ExamPercentage Decimal   @default(100) @db.Decimal(5, 2)
  MarkType       String    @default("EXAM") @db.VarChar(50)
  time           DateTime? @db.Date
  student        student   @relation(fields: [Student_id], references: [Student_id], onDelete: Cascade, onUpdate: Restrict, map: "fk_marks_student")
  subject        subject   @relation(fields: [Subject_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_marks_subject")
  createdAt      DateTime  @default(now()) @db.Timestamp(0)
  updatedAt      DateTime  @default(now()) @updatedAt @db.Timestamp(0)

  @@index([Subject_id], map: "idx_marks_subject_id")
  @@index([Student_id], map: "idx_marks_student_id")
}

model message_attachments {
  id          Int      @id @default(autoincrement())
  message_id  Int
  file_name   String   @db.VarChar(255)
  file_url    String   @db.VarChar(500)
  file_type   String?  @db.VarChar(100)
  file_size   BigInt?
  uploaded_at DateTime @default(now()) @db.Timestamp(0)
  messages    messages @relation(fields: [message_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_message_attachments_message")

  @@index([message_id], map: "idx_message_attachments_message_id")
}

model messages {
  id                  Int                    @id @default(autoincrement())
  chat_id             Int
  sender_user_id      Int
  replyToMessageId    Int?                   @map("reply_to_message_id")
  message_type        messages_message_type? @default(text)
  content             String                 @db.Text
  sent_at             DateTime               @default(now()) @db.Timestamp(0)
  is_seen             Boolean                @default(false)
  seen_at             DateTime?              @db.Timestamp(0)
  edited_at           DateTime?              @db.Timestamp(0)
  is_deleted          Boolean?               @default(false)
  message_attachments message_attachments[]
  reactions           message_reaction[]
  replyTo             messages?              @relation("MessageReplies", fields: [replyToMessageId], references: [id], onDelete: SetNull, onUpdate: Restrict)
  replies             messages[]             @relation("MessageReplies")
  chats               chats                  @relation(fields: [chat_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_messages_chat")
  user                user                   @relation(fields: [sender_user_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_messages_sender")

  @@index([chat_id], map: "idx_messages_chat_id")
  @@index([sender_user_id], map: "idx_messages_sender_user_id")
  @@index([replyToMessageId], map: "idx_messages_reply_to_message_id")
  @@index([sent_at], map: "idx_messages_sent_at")
}

model message_reaction {
  id         Int      @id @default(autoincrement())
  message_id Int
  user_id    Int
  reaction   String   @db.VarChar(32)
  created_at DateTime @default(now()) @db.Timestamp(0)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamp(0)
  message    messages @relation(fields: [message_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_message_reaction_message")
  user       user     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_message_reaction_user")

  @@unique([message_id, user_id], map: "uq_message_reaction_message_user")
  @@index([message_id], map: "idx_message_reaction_message")
  @@index([user_id], map: "idx_message_reaction_user")
}

model notification {
  id        Int      @id @default(autoincrement())
  User_id   Int
  content   String   @db.Text
  Type      String   @db.VarChar(100)
  Url       String?  @db.VarChar(500)
  isSeen    Boolean? @default(false)
  user      user     @relation(fields: [User_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_notification_user")
  createdAt DateTime @default(now()) @db.Timestamp(0)
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamp(0)

  @@index([User_id], map: "idx_notification_user_id")
}

model organization {
  id                     Int                           @id @default(autoincrement())
  Name                   String                        @db.VarChar(255)
  subdomain              String                        @unique @db.VarChar(63)
  Email                  String                        @unique(map: "Email") @db.VarChar(255)
  Password_Hashed        String                        @db.VarChar(255)
  PasswordResetToken     String?                       @db.VarChar(255)
  PasswordResetExpiresAt DateTime?                     @db.Timestamp(0)
  PasswordChangedAt      DateTime?                     @db.Timestamp(0)
  Phone                  String?                       @db.VarChar(50)
  Founded                DateTime?                     @db.Date
  Address                String?                       @db.VarChar(255)
  PhoneNumber            String?                       @db.VarChar(50)
  Description            String?                       @db.Text
  Role                   organization_Role
  academy_user           academy_user[]
  chats                  chats[]
  course                 course[]
  student                student[]
  teacher                teacher[]
  subscriptions          subscription[]
  payments               payment[]
  school_settings        organization_school_settings?
  promotion_runs         organization_promotion_run[]
  academic_years         academic_year[]
  student_notes          student_note[]
  status                 organization_status           @default(PENDING)
  createdAt              DateTime                      @default(now()) @db.Timestamp(0)
  updatedAt              DateTime                      @default(now()) @updatedAt @db.Timestamp(0)

  @@index([status], map: "idx_org_status")
}

model plan {
  id            Int            @id @default(autoincrement())
  name          String         @db.VarChar(100)
  price         Decimal        @db.Decimal(10, 2)
  durationDays  Int
  description   String?        @db.Text
  features      Json?
  planFeatures  plan_feature[]
  subscriptions subscription[]
  createdAt     DateTime       @default(now()) @db.Timestamp(0)
  updatedAt     DateTime       @default(now()) @updatedAt @db.Timestamp(0)

  @@index([name], map: "idx_plan_name")
}

model feature {
  id            Int            @id @default(autoincrement())
  featureKey    String         @unique @db.VarChar(100)
  name          String         @db.VarChar(255)
  description   String?        @db.Text
  hasLimit      Boolean        @default(false)
  defaultLimit  Int?
  planFeatures  plan_feature[]
  createdAt     DateTime       @default(now()) @db.Timestamp(0)
  updatedAt     DateTime       @default(now()) @updatedAt @db.Timestamp(0)

  @@index([featureKey], map: "idx_feature_feature_key")
}

model plan_feature {
  id           Int      @id @default(autoincrement())
  planId       Int
  featureId    Int
  featureLimit Int?
  plan         plan     @relation(fields: [planId], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_plan_feature_plan")
  feature      feature  @relation(fields: [featureId], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_plan_feature_feature")
  createdAt    DateTime @default(now()) @db.Timestamp(0)
  updatedAt    DateTime @default(now()) @updatedAt @db.Timestamp(0)

  @@unique([planId, featureId], map: "uq_plan_feature_plan_feature")
  @@index([planId], map: "idx_plan_feature_plan_id")
  @@index([featureId], map: "idx_plan_feature_feature_id")
}

model subscription {
  id             Int          @id @default(autoincrement())
  organizationId Int
  planId         Int
  startDate      DateTime     @default(now()) @db.Timestamp(0)
  endDate        DateTime     @db.Timestamp(0)
  status         String       @default("ACTIVE") @db.VarChar(50)
  autoRenew      Boolean      @default(true)
  organization   organization @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_subscription_org")
  plan           plan         @relation(fields: [planId], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "fk_subscription_plan")
  payments       payment[]
  createdAt      DateTime     @default(now()) @db.Timestamp(0)
  updatedAt      DateTime     @default(now()) @updatedAt @db.Timestamp(0)

  @@index([organizationId], map: "idx_subscription_org_id")
  @@index([planId], map: "idx_subscription_plan_id")
  @@index([status], map: "idx_subscription_status")
  @@index([endDate], map: "idx_subscription_end_date")
}

model payment {
  id             Int           @id @default(autoincrement())
  subscriptionId Int?
  organizationId Int
  amount         Decimal       @db.Decimal(10, 2)
  paymentDate    DateTime      @default(now()) @db.Timestamp(0)
  paymentMethod  String        @db.VarChar(50)
  status         String        @db.VarChar(50)
  organization   organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_payment_org")
  subscription   subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull, onUpdate: Restrict, map: "fk_payment_subscription")
  createdAt      DateTime      @default(now()) @db.Timestamp(0)
  updatedAt      DateTime      @default(now()) @updatedAt @db.Timestamp(0)

  @@index([organizationId], map: "idx_payment_org_id")
  @@index([subscriptionId], map: "idx_payment_subscription_id")
  @@index([status], map: "idx_payment_status")
}

model parent {
  Parent_id Int       @id
  nationalId String?  @unique @db.VarChar(50)
  Work      String?   @db.VarChar(255)
  user      user      @relation(fields: [Parent_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_parent_user")
  student   student[]
  createdAt DateTime  @default(now()) @db.Timestamp(0)
  updatedAt DateTime  @default(now()) @updatedAt @db.Timestamp(0)
}

model student {
  Student_id        Int                         @id
  Parent_id         Int?
  OrgId             Int
  Course_id         Int?
  DOB               DateTime?                   @db.Date
  GradeLevel        Int?
  AcademicStatus    String                      @default("ACTIVE") @db.VarChar(20)
  course            course?                     @relation(fields: [Course_id], references: [id], onUpdate: Restrict, map: "fk_student_course")
  promotion_history student_promotion_history[]
  marks             marks[]
  organization      organization                @relation(fields: [OrgId], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_student_org")
  parent            parent?                     @relation(fields: [Parent_id], references: [Parent_id], onUpdate: Restrict, map: "fk_student_parent")
  user              user                        @relation(fields: [Student_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_student_user")
  student_notes     student_note[]
  createdAt         DateTime                    @default(now()) @db.Timestamp(0)
  updatedAt         DateTime                    @default(now()) @updatedAt @db.Timestamp(0)

  @@index([Course_id], map: "idx_student_course_id")
  @@index([GradeLevel], map: "idx_student_grade_level")
  @@index([AcademicStatus], map: "idx_student_academic_status")
  @@index([OrgId], map: "idx_student_org_id")
  @@index([Parent_id], map: "idx_student_parent_id")
}

model student_note {
  id        Int      @id @default(autoincrement())
  studentId Int
  teacherId Int
  orgId     Int
  title     String?  @db.VarChar(255)
  content   String   @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now()) @db.Timestamp(0)
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamp(0)

  student student      @relation(fields: [studentId], references: [Student_id], onDelete: Cascade)
  teacher teacher      @relation(fields: [teacherId], references: [Teacher_id], onDelete: Cascade)
  org     organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([teacherId])
  @@index([orgId])
}

model organization_school_settings {
  id                       Int          @id @default(autoincrement())
  OrgId                    Int          @unique
  schoolYearStartMonth     Int          @default(9)
  schoolYearStartDay       Int          @default(1)
  promotionMonth           Int          @default(9)
  promotionDay             Int          @default(1)
  entryGradeMinAge         Int          @default(6)
  passThresholdPercentage  Decimal      @default(50) @db.Decimal(5, 2)
  minSubjectPassPercentage Decimal      @default(50) @db.Decimal(5, 2)
  requireAllSubjectsPass   Boolean      @default(true)
  classRanges              Json?
  organization             organization @relation(fields: [OrgId], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_school_settings_org")
  createdAt                DateTime     @default(now()) @db.Timestamp(0)
  updatedAt                DateTime     @default(now()) @updatedAt @db.Timestamp(0)
}

model organization_promotion_run {
  id           Int          @id @default(autoincrement())
  OrgId        Int
  schoolYear   Int
  status       String       @default("SUCCESS") @db.VarChar(20)
  summary      Json?
  organization organization @relation(fields: [OrgId], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_promotion_run_org")
  createdAt    DateTime     @default(now()) @db.Timestamp(0)

  @@unique([OrgId, schoolYear], map: "uq_org_promotion_run_school_year")
  @@index([OrgId], map: "idx_org_promotion_run_org")
}

model student_promotion_history {
  id              Int      @id @default(autoincrement())
  Student_id      Int
  OrgId           Int
  fromGradeLevel  Int?
  toGradeLevel    Int?
  decision        String   @db.VarChar(20)
  finalPercentage Decimal? @db.Decimal(5, 2)
  reason          String?  @db.VarChar(255)
  schoolYear      Int
  promotedAt      DateTime @default(now()) @db.Timestamp(0)
  student         student  @relation(fields: [Student_id], references: [Student_id], onDelete: Cascade, onUpdate: Restrict, map: "fk_student_promotion_history_student")

  @@unique([Student_id, schoolYear], map: "uq_student_promotion_history_school_year")
  @@index([OrgId], map: "idx_student_promotion_history_org")
  @@index([Student_id], map: "idx_student_promotion_history_student")
  @@index([schoolYear], map: "idx_student_promotion_history_school_year")
}

model subject {
  id          Int      @id @default(autoincrement())
  Course_id   Int
  Teacher_id  Int?
  name        String   @db.VarChar(255)
  level       String?  @db.VarChar(20)
  isPaid      Boolean  @default(false)
  price       Decimal  @default(0) @db.Decimal(10, 2)
  imageUrl    String   @default("") @db.VarChar(500)
  Description String?  @db.Text
  chats       chats[]
  lesson      lesson[]
  marks       marks[]
  subscriptions student_subject_subscription[]
  course      course   @relation(fields: [Course_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_subject_course")
  teacher     teacher? @relation(fields: [Teacher_id], references: [Teacher_id], onDelete: Cascade, onUpdate: Restrict, map: "fk_subject_teacher")
  createdAt   DateTime @default(now()) @db.Timestamp(0)
  updatedAt   DateTime @default(now()) @updatedAt @db.Timestamp(0)

  @@index([Course_id], map: "idx_subject_course_id")
  @@index([Teacher_id], map: "idx_subject_teacher_id")
  @@index([isPaid], map: "idx_subject_is_paid")
}

model student_subject_subscription {
  id                Int          @id @default(autoincrement())
  user_Academy_id   Int
  Subject_id        Int
  amount            Decimal      @default(0) @db.Decimal(10, 2)
  paymentMethod     String       @default("MANUAL") @db.VarChar(50)
  paymentStatus     String       @default("PENDING") @db.VarChar(20)
  stripeSessionId   String?      @db.VarChar(500)
  status            String       @default("SUCCESS") @db.VarChar(50)
  paidAt            DateTime?    @db.Timestamp(0)
  createdAt         DateTime     @default(now()) @db.Timestamp(0)
  updatedAt         DateTime     @default(now()) @updatedAt @db.Timestamp(0)
  academy_user      academy_user @relation(fields: [user_Academy_id], references: [user_academy_id], onDelete: Cascade, onUpdate: Restrict, map: "fk_student_subject_subscription_academy_user")
  subject           subject      @relation(fields: [Subject_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_student_subject_subscription_subject")

  @@unique([user_Academy_id, Subject_id], map: "uq_student_subject_subscription")
  @@index([user_Academy_id], map: "idx_student_subject_subscription_user")
  @@index([Subject_id], map: "idx_student_subject_subscription_subject")
  @@index([status], map: "idx_student_subject_subscription_status")
}

model teacher {
  Teacher_id     Int            @id
  OrgId          Int
  Work           String?        @db.VarChar(255)
  specialization String?        @db.VarChar(255)
  bio            String?        @db.Text
  createdAt      DateTime       @default(now()) @db.Timestamp(0)
  organization   organization   @relation(fields: [OrgId], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_teacher_org")
  course         course[]
  subject        subject[]
  user           user           @relation(fields: [Teacher_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_teacher_user")
  student_notes  student_note[]

  @@index([OrgId], map: "idx_teacher_org_id")
}

model user {
  id                     Int                 @id @default(autoincrement())
  name                   String              @db.VarChar(255)
  age                    Int?
  gender                 user_Gender?
  email                  String              @unique(map: "Email") @db.VarChar(255)
  passwordHashed         String              @db.VarChar(255)
  passwordEncrypted      String?             @db.VarChar(1024)
  passwordResetToken     String?             @db.VarChar(255)
  passwordResetExpiresAt DateTime?           @db.Timestamp(0)
  passwordChangedAt      DateTime?           @db.Timestamp(0)
  address                String?             @db.VarChar(255)
  role                   user_Role
  academy_user           academy_user?
  chat_participants      chat_participants[]
  chats                  chats[]
  comment                comment[]
  messages               messages[]
  message_reactions      message_reaction[]
  notification           notification[]
  lesson_progress        lesson_progress[]
  quiz_attempts          quiz_attempt[]
  parent                 parent?
  student                student?
  teacher                teacher?
  term_audit_logs        term_edit_audit[]
  studentXpSummary       student_xp_summary?
  xpEvents               xp_event[]
  studentStreak          student_streak?
  achievements           student_achievement[]
  missionProgress        student_mission_progress[]
  createdAt              DateTime            @default(now()) @db.Timestamp(0)
  updatedAt              DateTime            @default(now()) @updatedAt @db.Timestamp(0)
}

model student_xp_summary {
  id        Int      @id @default(autoincrement())
  studentId Int      @unique
  totalXp   Int      @default(0)
  level     Int      @default(1)
  updatedAt DateTime @updatedAt
  user      user     @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model xp_event {
  id         Int           @id @default(autoincrement())
  studentId  Int
  eventType  xp_event_type
  xpAwarded  Int
  sourceType String        @db.VarChar(50)
  sourceId   Int
  metadata   Json?
  createdAt  DateTime      @default(now())
  user       user          @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, eventType, sourceType, sourceId], name: "uq_xp_event_source")
  @@index([studentId], map: "idx_xp_event_student")
}

model student_streak {
  id               Int       @id @default(autoincrement())
  studentId        Int       @unique
  currentStreak    Int       @default(0)
  longestStreak    Int       @default(0)
  lastActivityAt   DateTime?
  user             user      @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

enum chat_participants_role_in_chat {
  member
  admin
  teacher
  student
}

enum messages_message_type {
  text
  image
  file
  voice
}

enum user_Gender {
  FEMALE
  MALE
}

enum chats_type {
  GROUP
  PRIVATE
  COURSE_GROUP
  CLASS_GROUP
}

enum user_Role {
  STUDENT
  PARENT
  ADMIN
  ACADEMY
  TEACHER
}

enum organization_Role {
  ACADEMY
  SCHOOL
}

enum organization_status {
  PENDING
  APPROVED
  REJECTED
}

enum lesson_attachment_file_type {
  PDF
  DOCX
  TXT
  IMAGE
  VIDEO
  AUDIO
  OTHER
}

enum course_kind {
  CLASS
  TRACK
}

enum term_status {
  PLANNED
  ACTIVE
  CLOSED
  LOCKED
}

model academic_year {
  id            Int           @id @default(autoincrement())
  OrgId         Int
  name          String        @db.VarChar(100)
  startDate     DateTime      @db.Date
  endDate       DateTime      @db.Date
  numberOfTerms Int           @default(1)
  isActive      Boolean       @default(false)
  organization  organization  @relation(fields: [OrgId], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_academic_year_org")
  terms         term[]
  createdAt     DateTime      @default(now()) @db.Timestamp(0)
  updatedAt     DateTime      @default(now()) @updatedAt @db.Timestamp(0)

  @@unique([OrgId, isActive], map: "uq_org_active_academic_year")
  @@index([OrgId], map: "idx_academic_year_org")
  @@index([isActive], map: "idx_academic_year_is_active")
}

model term {
  id             Int           @id @default(autoincrement())
  academicYearId Int
  termNumber     Int
  name           String        @db.VarChar(100)
  startDate      DateTime      @db.Date
  endDate        DateTime      @db.Date
  status         term_status   @default(PLANNED)
  academic_year  academic_year @relation(fields: [academicYearId], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_term_academic_year")
  audit_logs     term_edit_audit[]
  createdAt      DateTime      @default(now()) @db.Timestamp(0)
  updatedAt      DateTime      @default(now()) @updatedAt @db.Timestamp(0)

  @@unique([academicYearId, termNumber], map: "uq_academic_year_term_number")
  @@index([academicYearId], map: "idx_term_academic_year")
  @@index([status], map: "idx_term_status")
  @@index([startDate], map: "idx_term_start_date")
  @@index([endDate], map: "idx_term_end_date")
}

model term_edit_audit {
  id              Int      @id @default(autoincrement())
  termId          Int
  OrgId           Int
  updatedByUserId Int
  oldValues       Json?
  newValues       Json?
  actionType      String   @db.VarChar(50)
  changeReason    String?  @db.Text
  term            term     @relation(fields: [termId], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_term_audit_term")
  user            user     @relation(fields: [updatedByUserId], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "fk_term_audit_user")
  createdAt       DateTime @default(now()) @db.Timestamp(0)

  @@index([termId], map: "idx_term_audit_term")
  @@index([OrgId], map: "idx_term_audit_org")
  @@index([updatedByUserId], map: "idx_term_audit_user")
  @@index([actionType], map: "idx_term_audit_action_type")
  @@index([createdAt], map: "idx_term_audit_created_at")
}

enum xp_event_type {
  LESSON_COMPLETE
  QUIZ_PASS
  QUIZ_PERFECT
}

enum mission_type {
  DAILY
  WEEKLY
}

model student_achievement {
  id             Int      @id @default(autoincrement())
  studentId      Int
  achievementKey String   @db.VarChar(100)
  xpAwarded      Int
  unlockedAt     DateTime @default(now())
  user           user     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, achievementKey], name: "uq_student_achievement")
  @@index([studentId])
}

model student_mission_progress {
  id          Int          @id @default(autoincrement())
  studentId   Int
  missionKey  String       @db.VarChar(100)
  type        mission_type
  progress    Int          @default(0)
  goal        Int
  completed   Boolean      @default(false)
  periodStart DateTime
  xpAwarded   Int          @default(0)
  user        user         @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, missionKey, periodStart], name: "uq_mission_period")
  @@index([studentId])
}
