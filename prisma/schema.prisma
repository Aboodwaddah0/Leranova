generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model academy_user {
  user_academy_id         Int                        @id
  OrgId                   Int
  DOB                     DateTime?                  @db.Date
  AcademicStatus          String                     @default("ACTIVE") @db.VarChar(20)
  organization            organization               @relation(fields: [OrgId], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_academy_user_org")
  user                    user                       @relation(fields: [user_academy_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_academy_user_user")
  enrollment              enrollment[]
  student_course_payment  student_course_payment[]
  subject_subscriptions   student_subject_subscription[]
  createdAt               DateTime                   @default(now()) @db.Timestamp(0)
  updatedAt               DateTime                   @default(now()) @updatedAt @db.Timestamp(0)

  @@index([OrgId], map: "fk_academy_user_org")
  @@index([AcademicStatus], map: "idx_academy_user_academic_status")
}

model chat_participants {
  id           Int                             @id @default(autoincrement())
  chat_id      Int
  user_id      Int
  role_in_chat chat_participants_role_in_chat? @default(member)
  joined_at    DateTime                        @default(now()) @db.Timestamp(0)
  chats        chats                           @relation(fields: [chat_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_chat_participants_chat")
  user         user                            @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_chat_participants_user")

  @@unique([chat_id, user_id], map: "uq_chat_participant")
  @@index([chat_id], map: "idx_chat_participants_chat_id")
  @@index([user_id], map: "idx_chat_participants_user_id")
}

model chats {
  id                Int                 @id @default(autoincrement())
  organization_id   Int
  course_id         Int?                @unique
  class_id          Int?
  subject_id        Int?
  created_by        Int
  type              chats_type
  title             String?             @db.VarChar(255)
  created_at        DateTime            @default(now()) @db.Timestamp(0)
  chat_participants chat_participants[]
  user              user                @relation(fields: [created_by], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_chats_created_by")
  organization      organization        @relation(fields: [organization_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_chats_organization")
  track             track?              @relation(fields: [course_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_chats_course")
  course            course?             @relation(fields: [subject_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_chats_subject")
  messages          messages[]

  @@index([created_by], map: "fk_chats_created_by")
  @@index([organization_id], map: "idx_chats_organization_id")
  @@index([course_id], map: "idx_chats_course_id")
  @@index([class_id], map: "idx_chats_class_id")
  @@index([subject_id], map: "idx_chats_subject_id")
  @@index([type], map: "idx_chats_type")
  @@unique([organization_id, class_id], map: "uq_chats_org_class")
}

model comment {
  id        Int      @id @default(autoincrement())
  lesson_id Int?
  User_id   Int
  time      DateTime @default(now()) @db.Timestamp(0)
  content   String   @db.Text
  lesson    lesson?  @relation(fields: [lesson_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_comment_lesson")
  user      user     @relation(fields: [User_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_comment_user")

  @@index([lesson_id], map: "idx_comment_lesson_id")
  @@index([User_id], map: "idx_comment_user_id")
}

model track {
  id                     Int                       @id @default(autoincrement())
  Org_id                 Int
  Teacher_id             Int?
  Name                   String                    @db.VarChar(255)
  kind                   course_kind               @default(TRACK)
  GradeLevel             Int?
  Description            String?                   @db.Text
  Thumbnail              String?                   @db.VarChar(500)

  price                  Decimal                   @default(0) @db.Decimal(10, 2)
  isPaid                 Boolean                   @default(false)
  level                  String?                   @db.VarChar(20)

  organization           organization              @relation(fields: [Org_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_course_org")
  teacher                teacher?                  @relation(fields: [Teacher_id], references: [Teacher_id], onDelete: SetNull, onUpdate: Restrict, map: "fk_course_teacher")
  student                student[]
  courses                course[]
  enrollment             enrollment[]

  chats                  chats[]

  student_course_payment student_course_payment[]
  attendance             attendance[]             @relation("class_attendance")
  certificates           student_certificate[]
  timetable_slots        timetable_slot[]

  createdAt              DateTime                  @default(now()) @db.Timestamp(0)
  updatedAt              DateTime                  @default(now()) @updatedAt @db.Timestamp(0)

  @@index([Org_id], map: "idx_course_org_id")
  @@index([Teacher_id], map: "idx_course_teacher_id")
  @@index([kind], map: "idx_course_kind")
  @@index([GradeLevel], map: "idx_course_grade_level")
  @@index([isPaid], map: "idx_course_is_paid")
  @@map("course")
}

model enrollment {
  user_Academy_id Int
  Course_id       Int
  academy_user    academy_user @relation(fields: [user_Academy_id], references: [user_academy_id], onDelete: Cascade, onUpdate: Restrict, map: "fk_enrollment_academy_user")
  track           track        @relation(fields: [Course_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_enrollment_course")
  createdAt       DateTime     @default(now()) @db.Timestamp(0)
  updatedAt       DateTime     @default(now()) @updatedAt @db.Timestamp(0)

  @@id([user_Academy_id, Course_id])
  @@index([Course_id], map: "fk_enrollment_course")
}

model student_course_payment {
  id                    Int          @id @default(autoincrement())
  user_Academy_id       Int
  Course_id             Int
  amount                Decimal      @db.Decimal(10, 2)
  paymentMethod         String       @default("STRIPE") @db.VarChar(50)
  status                String       @default("PENDING") @db.VarChar(50)
  stripePaymentIntentId String?      @db.VarChar(500)
  paidAt                DateTime?    @db.Timestamp(0)
  academy_user          academy_user @relation(fields: [user_Academy_id], references: [user_academy_id], onDelete: Cascade, onUpdate: Restrict, map: "fk_student_course_payment_academy_user")
  track                 track        @relation(fields: [Course_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_student_course_payment_course")
  createdAt             DateTime     @default(now()) @db.Timestamp(0)
  updatedAt             DateTime     @default(now()) @updatedAt @db.Timestamp(0)

  @@unique([user_Academy_id, Course_id], map: "uq_student_course_payment")
  @@index([user_Academy_id], map: "idx_student_course_payment_user")
  @@index([Course_id], map: "idx_student_course_payment_course")
  @@index([status], map: "idx_student_course_payment_status")
}

model lesson {
  id                 Int                  @id @default(autoincrement())
  Subject_id         Int
  name               String               @db.VarChar(255)
  Description        String?              @db.Text
  comment            comment[]
  lesson_transcripts lesson_transcripts[]
  lesson_progress    lesson_progress[]
  course             course               @relation(fields: [Subject_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_lesson_subject")
  rag_assets         lesson_rag_asset[]
  attachments        lesson_attachment[]
  ai_content         lesson_ai_content?
  quiz               quiz?
  createdAt          DateTime             @default(now()) @db.Timestamp(0)
  updatedAt          DateTime             @default(now()) @updatedAt @db.Timestamp(0)

  @@index([Subject_id], map: "idx_lesson_subject_id")
}

model quiz {
  id            Int             @id @default(autoincrement())
  lessonId      Int             @unique
  title         String          @db.VarChar(255)
  description   String?         @db.Text
  difficulty    String          @default("MEDIUM") @db.VarChar(10)
  passingScore  Int             @default(70)
  isPublished   Boolean         @default(false)
  isHidden      Boolean         @default(false)
  availableFrom DateTime?       @db.Timestamp(0)
  availableTo   DateTime?       @db.Timestamp(0)
  lesson        lesson          @relation(fields: [lessonId], references: [id], onDelete: Cascade, map: "fk_quiz_lesson")
  questions     quiz_question[]
  attempts      quiz_attempt[]
  createdAt     DateTime        @default(now()) @db.Timestamp(0)
  updatedAt     DateTime        @default(now()) @updatedAt @db.Timestamp(0)

  @@index([lessonId], map: "idx_quiz_lesson_id")
}

model quiz_question {
  id             Int      @id @default(autoincrement())
  quizId         Int
  lang           String   @default("ar") @db.VarChar(5)
  type           String   @default("MULTIPLE_CHOICE") @db.VarChar(30)
  question       String   @db.Text
  options        Json
  correctAnswer  Int?
  expectedAnswer String?  @db.Text
  explanation    String?  @db.Text
  orderIndex     Int      @default(0)
  quiz           quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade, map: "fk_quiz_question_quiz")
  createdAt      DateTime @default(now()) @db.Timestamp(0)
  updatedAt      DateTime @default(now()) @updatedAt @db.Timestamp(0)

  @@index([quizId], map: "idx_quiz_question_quiz_id")
  @@index([quizId, lang], map: "idx_quiz_question_quiz_lang")
}

model quiz_attempt {
  id         Int      @id @default(autoincrement())
  quizId     Int
  studentId  Int
  answers    Json
  score      Int
  isPassed   Boolean
  aiGrading  Json?
  quiz       quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade, map: "fk_quiz_attempt_quiz")
  student    user     @relation(fields: [studentId], references: [id], onDelete: Cascade, map: "fk_quiz_attempt_user")
  createdAt  DateTime @default(now()) @db.Timestamp(0)

  @@index([quizId], map: "idx_quiz_attempt_quiz_id")
  @@index([studentId], map: "idx_quiz_attempt_student_id")
}

model lesson_ai_content {
  id                  Int       @id @default(autoincrement())
  lessonId            Int       @unique
  flashcards          Json
  mindmap             Json
  status              String    @default("draft")
  publishedAt         DateTime?
  videoOverviewUrl      String?   @db.VarChar(500)
  videoOverviewStatus   String?   @db.VarChar(20)
  interactiveContent    Json?
  interactiveStatus     String?   @db.VarChar(20)
  powerSlides           Json?
  createdAt             DateTime  @default(now()) @db.Timestamp(0)
  updatedAt           DateTime  @default(now()) @updatedAt @db.Timestamp(0)
  lesson              lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_lesson_ai_content_lesson")
}

model lesson_attachment {
  id               Int                         @id @default(autoincrement())
  lessonId         Int
  fileUrl          String                      @db.VarChar(500)
  filePublicId     String                      @db.VarChar(255)
  fileResourceType String                      @db.VarChar(50)
  mimeType         String?                     @db.VarChar(100)
  originalName     String?                     @db.VarChar(255)
  fileType         lesson_attachment_file_type
  sizeBytes        BigInt?
  createdAt        DateTime                    @default(now()) @db.Timestamp(0)
  updatedAt        DateTime                    @default(now()) @updatedAt @db.Timestamp(0)
  lesson           lesson                      @relation(fields: [lessonId], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_lesson_attachment_lesson")

  @@index([lessonId], map: "idx_lesson_attachment_lesson_id")
  @@index([fileType], map: "idx_lesson_attachment_file_type")
}

model lesson_rag_asset {
  id            Int      @id @default(autoincrement())
  lessonId      Int
  type          String   @db.VarChar(20)
  fileUrl       String   @db.VarChar(500)
  extractedText String?  @db.LongText
  sourceName    String?  @db.VarChar(255)
  createdAt     DateTime @default(now()) @db.Timestamp(0)
  lesson        lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_lesson_rag_asset_lesson")

  @@index([lessonId], map: "idx_lesson_rag_asset_lesson_id")
  @@index([type], map: "idx_lesson_rag_asset_type")
}

model lesson_transcripts {
  id         Int      @id @default(autoincrement())
  lesson_id  Int
  transcript String   @db.LongText
  created_at DateTime @default(now()) @db.Timestamp(0)
  lesson     lesson   @relation(fields: [lesson_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_lesson_transcripts_lesson")

  @@index([lesson_id], map: "idx_lesson_transcripts_lesson_id")
}

model lesson_progress {
  id                   Int      @id @default(autoincrement())
  studentId            Int
  lessonId             Int
  isCompleted          Boolean  @default(false)
  watchedSeconds       Int      @default(0)
  videoDurationSeconds Int?
  createdAt            DateTime @default(now()) @db.Timestamp(0)
  updatedAt            DateTime @default(now()) @updatedAt @db.Timestamp(0)
  student              user     @relation(fields: [studentId], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_lesson_progress_student")
  lesson               lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_lesson_progress_lesson")

  @@unique([studentId, lessonId], map: "uq_lesson_progress_student_lesson")
  @@index([studentId], map: "idx_lesson_progress_student")
  @@index([lessonId], map: "idx_lesson_progress_lesson")
}

model marks {
  id             Int                   @id @default(autoincrement())
  Student_id     Int
  Subject_id     Int
  Numbers        Decimal               @db.Decimal(5, 2)
  OutOf          Decimal               @default(100) @db.Decimal(5, 2)
  ExamPercentage Decimal               @default(100) @db.Decimal(5, 2)
  MarkType       String                @default("EXAM") @db.VarChar(50)
  time           DateTime?             @db.Date
  termId         Int?
  componentId    Int?
  student        student               @relation(fields: [Student_id], references: [Student_id], onDelete: Cascade, onUpdate: Restrict, map: "fk_marks_student")
  course         course                @relation(fields: [Subject_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_marks_subject")
  term           term?                 @relation(fields: [termId], references: [id], onDelete: SetNull, onUpdate: Restrict, map: "fk_marks_term")
  component      assessment_component? @relation(fields: [componentId], references: [id], onDelete: SetNull, onUpdate: Restrict, map: "fk_marks_component")
  createdAt      DateTime              @default(now()) @db.Timestamp(0)
  updatedAt      DateTime              @default(now()) @updatedAt @db.Timestamp(0)

  @@index([Subject_id], map: "idx_marks_subject_id")
  @@index([Student_id], map: "idx_marks_student_id")
  @@index([termId], map: "idx_marks_term_id")
  @@index([componentId], map: "idx_marks_component_id")
}

model message_attachments {
  id          Int      @id @default(autoincrement())
  message_id  Int
  file_name   String   @db.VarChar(255)
  file_url    String   @db.VarChar(500)
  file_type   String?  @db.VarChar(100)
  file_size   BigInt?
  uploaded_at DateTime @default(now()) @db.Timestamp(0)
  messages    messages @relation(fields: [message_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_message_attachments_message")

  @@index([message_id], map: "idx_message_attachments_message_id")
}

model messages {
  id                  Int                    @id @default(autoincrement())
  chat_id             Int
  sender_user_id      Int
  replyToMessageId    Int?                   @map("reply_to_message_id")
  message_type        messages_message_type? @default(text)
  content             String                 @db.Text
  sent_at             DateTime               @default(now()) @db.Timestamp(0)
  is_seen             Boolean                @default(false)
  seen_at             DateTime?              @db.Timestamp(0)
  edited_at           DateTime?              @db.Timestamp(0)
  is_deleted          Boolean?               @default(false)
  message_attachments message_attachments[]
  reactions           message_reaction[]
  replyTo             messages?              @relation("MessageReplies", fields: [replyToMessageId], references: [id], onDelete: SetNull, onUpdate: Restrict)
  replies             messages[]             @relation("MessageReplies")
  chats               chats                  @relation(fields: [chat_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_messages_chat")
  user                user                   @relation(fields: [sender_user_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_messages_sender")

  @@index([chat_id], map: "idx_messages_chat_id")
  @@index([sender_user_id], map: "idx_messages_sender_user_id")
  @@index([replyToMessageId], map: "idx_messages_reply_to_message_id")
  @@index([sent_at], map: "idx_messages_sent_at")
}

model message_reaction {
  id         Int      @id @default(autoincrement())
  message_id Int
  user_id    Int
  reaction   String   @db.VarChar(32)
  created_at DateTime @default(now()) @db.Timestamp(0)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamp(0)
  message    messages @relation(fields: [message_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_message_reaction_message")
  user       user     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_message_reaction_user")

  @@unique([message_id, user_id], map: "uq_message_reaction_message_user")
  @@index([message_id], map: "idx_message_reaction_message")
  @@index([user_id], map: "idx_message_reaction_user")
}

model notification {
  id        Int      @id @default(autoincrement())
  User_id   Int
  content   String   @db.Text
  Type      String   @db.VarChar(100)
  Url       String?  @db.VarChar(500)
  isSeen    Boolean? @default(false)
  user      user     @relation(fields: [User_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_notification_user")
  createdAt DateTime @default(now()) @db.Timestamp(0)
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamp(0)

  @@index([User_id], map: "idx_notification_user_id")
}

model organization {
  id                     Int                           @id @default(autoincrement())
  Name                   String                        @db.VarChar(255)
  Email                  String                        @unique(map: "Email") @db.VarChar(255)
  Password_Hashed        String                        @db.VarChar(255)
  PasswordResetToken     String?                       @db.VarChar(255)
  PasswordResetExpiresAt DateTime?                     @db.Timestamp(0)
  PasswordChangedAt      DateTime?                     @db.Timestamp(0)
  Phone                  String?                       @db.VarChar(50)
  Founded                DateTime?                     @db.Date
  Address                String?                       @db.VarChar(255)
  PhoneNumber            String?                       @db.VarChar(50)
  Description            String?                       @db.Text
  Role                   organization_Role
  status                 organization_status           @default(PENDING)
  emailVerificationToken     String?                   @db.VarChar(255)
  emailVerificationExpiresAt DateTime?                 @db.Timestamp(0)
  rejectionReason            String?                   @db.Text
  trialEndsAt                DateTime?                 @db.Timestamp(0)
  academy_user           academy_user[]
  chats                  chats[]
  track                  track[]
  student                student[]
  teacher                teacher[]
  subscriptions          subscription[]
  payments               payment[]
  school_settings        organization_school_settings?
  promotion_runs         organization_promotion_run[]
  academic_years         academic_year[]
  student_notes          student_note[]
  school_events          school_event[]
  attendance             attendance[]
  certificates           student_certificate[]
  timetable_slots        timetable_slot[]
  userSequence           Int                           @default(0)
  organizationCode       String?                       @unique @db.VarChar(20)
  fcmToken               String?                       @db.VarChar(500)
  createdAt              DateTime                      @default(now()) @db.Timestamp(0)
  updatedAt              DateTime                      @default(now()) @updatedAt @db.Timestamp(0)

  @@index([status], map: "idx_org_status")
  @@index([trialEndsAt], map: "idx_organization_trial_ends_at")
}

model plan {
  id            Int            @id @default(autoincrement())
  name          String         @db.VarChar(100)
  price         Decimal        @db.Decimal(10, 2)
  durationDays  Int
  description   String?        @db.Text
  features      Json?
  planFeatures  plan_feature[]
  subscriptions subscription[]
  createdAt     DateTime       @default(now()) @db.Timestamp(0)
  updatedAt     DateTime       @default(now()) @updatedAt @db.Timestamp(0)

  @@index([name], map: "idx_plan_name")
}

model feature {
  id            Int            @id @default(autoincrement())
  featureKey    String         @unique @db.VarChar(100)
  name          String         @db.VarChar(255)
  description   String?        @db.Text
  hasLimit      Boolean        @default(false)
  defaultLimit  Int?
  planFeatures  plan_feature[]
  createdAt     DateTime       @default(now()) @db.Timestamp(0)
  updatedAt     DateTime       @default(now()) @updatedAt @db.Timestamp(0)

  @@index([featureKey], map: "idx_feature_feature_key")
}

model plan_feature {
  id           Int      @id @default(autoincrement())
  planId       Int
  featureId    Int
  featureLimit Int?
  plan         plan     @relation(fields: [planId], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_plan_feature_plan")
  feature      feature  @relation(fields: [featureId], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_plan_feature_feature")
  createdAt    DateTime @default(now()) @db.Timestamp(0)
  updatedAt    DateTime @default(now()) @updatedAt @db.Timestamp(0)

  @@unique([planId, featureId], map: "uq_plan_feature_plan_feature")
  @@index([planId], map: "idx_plan_feature_plan_id")
  @@index([featureId], map: "idx_plan_feature_feature_id")
}

model subscription {
  id             Int          @id @default(autoincrement())
  organizationId Int
  planId         Int
  startDate      DateTime     @default(now()) @db.Timestamp(0)
  endDate        DateTime     @db.Timestamp(0)
  status         String       @default("ACTIVE") @db.VarChar(50)
  autoRenew      Boolean      @default(true)
  organization   organization @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_subscription_org")
  plan           plan         @relation(fields: [planId], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "fk_subscription_plan")
  payments       payment[]
  createdAt      DateTime     @default(now()) @db.Timestamp(0)
  updatedAt      DateTime     @default(now()) @updatedAt @db.Timestamp(0)

  @@index([organizationId], map: "idx_subscription_org_id")
  @@index([planId], map: "idx_subscription_plan_id")
  @@index([status], map: "idx_subscription_status")
  @@index([endDate], map: "idx_subscription_end_date")
}

model payment {
  id             Int           @id @default(autoincrement())
  subscriptionId Int?
  organizationId Int
  amount         Decimal       @db.Decimal(10, 2)
  paymentDate    DateTime      @default(now()) @db.Timestamp(0)
  paymentMethod  String        @db.VarChar(50)
  status         String        @db.VarChar(50)
  organization   organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_payment_org")
  subscription   subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull, onUpdate: Restrict, map: "fk_payment_subscription")
  createdAt      DateTime      @default(now()) @db.Timestamp(0)
  updatedAt      DateTime      @default(now()) @updatedAt @db.Timestamp(0)

  @@index([organizationId], map: "idx_payment_org_id")
  @@index([subscriptionId], map: "idx_payment_subscription_id")
  @@index([status], map: "idx_payment_status")
}

model parent {
  Parent_id Int       @id
  nationalId String?  @unique @db.VarChar(50)
  Work      String?   @db.VarChar(255)
  user      user      @relation(fields: [Parent_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_parent_user")
  student   student[]
  createdAt DateTime  @default(now()) @db.Timestamp(0)
  updatedAt DateTime  @default(now()) @updatedAt @db.Timestamp(0)
}

model student {
  Student_id        Int                         @id
  Parent_id         Int?
  OrgId             Int
  Course_id         Int?
  DOB               DateTime?                   @db.Date
  GradeLevel        Int?
  AcademicStatus    String                      @default("ACTIVE") @db.VarChar(20)
