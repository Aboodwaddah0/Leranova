  @@index([orgId, date], map: "idx_attendance_org_date")
  @@index([studentId], map: "idx_attendance_student")
  @@index([academicYearId], map: "idx_attendance_academic_year")
  @@index([subjectId], map: "idx_attendance_subject")
}

